rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isMe(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // ユーザー（自分のみ）
    match /users/{uid} {
      allow read, write: if isMe(uid);
    }

    // ワーカー（検索で読むため read はログインユーザーに許可）
    match /workers/{uid} {
      allow read: if signedIn();

      // 本人は自由に更新OK
      allow create, update, delete: if isMe(uid);

      // 評価集計の更新だけは、評価投稿時に他ユーザーからも更新される（MVP）
      allow update: if signedIn()
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['rating', 'ratingCount', 'ratingTotal', 'updatedAt']);
    }

    // 振込先（本人のみ）
    match /workerPayouts/{uid} {
      allow read, write: if isMe(uid);
    }

    // 依頼（作成者が書ける、読取はログインで許可/MVP）
    match /jobRequests/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.clientId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.clientId == request.auth.uid;
    }

    // 応募（ワーカー→依頼への応募）
    // docId 例: {jobRequestId}_{workerId}
    match /jobApplications/{id} {
      allow create: if signedIn() && request.resource.data.workerId == request.auth.uid;
      allow read: if signedIn()
        && (resource.data.workerId == request.auth.uid
            || resource.data.clientId == request.auth.uid);
      allow update, delete: if signedIn() && resource.data.workerId == request.auth.uid;
    }

    // クーポン（本人のみ）
    match /userCoupons/{id} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // 評価（投稿者が作成、投稿者or対象ワーカーが閲覧/MVP）
    match /ratings/{id} {
      allow create: if signedIn() && request.resource.data.raterId == request.auth.uid;
      allow read: if signedIn()
        && (resource.data.raterId == request.auth.uid
            || resource.data.targetWorkerId == request.auth.uid);
      allow update, delete: if false;
    }

    // 通知（本人のみ）
    match /notifications/{id} {
      allow read, update, delete: if signedIn() && resource.data.userId == request.auth.uid;
      // MVPではクライアント作成も許可（本番はサーバー発行推奨）
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
    }

    // チャット（スレッドメンバーのみ）
    match /chatThreads/{threadId} {
      allow create: if signedIn()
        && request.resource.data.memberIds is list
        && request.auth.uid in request.resource.data.memberIds;
      allow read: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow update, delete: if signedIn() && request.auth.uid in resource.data.memberIds;

      match /messages/{messageId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chatThreads/$(threadId)).data.memberIds;
        allow create: if signedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/chatThreads/$(threadId)).data.memberIds;
        allow update, delete: if false;
      }
    }

    // ワーカー統計（本人のみ / MVP）
    match /workerStats/{uid} {
      allow read, write: if isMe(uid);
    }
  }
}

